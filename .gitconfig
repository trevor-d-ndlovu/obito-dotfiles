[user]
	name = trotfiles
	email = sosaaisbacc@gmail.com

[init]
	defaultBranch = main

[core]
	editor = code --wait
	pager = delta

[color]
	ui = auto

[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold

[color "status"]
	added = green
	changed = yellow
	untracked = red

[pull]
	rebase = true

[rebase]
	autoStash = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[diff]
	colorMoved = default

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = auto

[interactive]
	diffFilter = delta --color-only

[merge]
	conflictStyle = zdiff3

[rerere]
	enabled = true

[credential]
	helper = cache

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	sw = switch
	rs = restore
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD --stat
	type = cat-file -t
	dump = cat-file -p
